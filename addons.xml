<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repo.kaisno07" name="Kaisno07 Repository" version="1.0.0" provider-name="kaisno07">
    <extension point="xbmc.addon.repository" name="Kaisno07 Repository">
        <dir>
            <info compressed="false">https://kaisno07.github.io/addons.xml</info>
            <checksum>https://kaisno07.github.io/addons.xml.md5</checksum>
            <datadir zip="true">https://kaisno07.github.io/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Kaisno07 Personal Repository</summary>
        <description>Kho add-on Kodi ca nhan cua Kaisno07</description>
        <platform>all</platform>
    </extension>
</addon>
<addon id="plugin.video.myfshare" name="MyFshare Player" version="1.1.6" provider-name="Personal">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" version="2.31.0"/>
    <import addon="script.module.beautifulsoup4" version="4.12.2"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">MyFshare Personal Player</summary>
    <description lang="en_GB">Xem phim ca nhan tu Fshare VIP</description>
    <platform>all</platform>
    <license>GPL-3.0</license>
  </extension>
</addon>
</addons>
